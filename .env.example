# Copy to .env and fill in your key. Keys prefixed with EXPO_PUBLIC_ are embedded
# into the client bundle — fine for demos, NOT fine for a production build that
# ships to end users.
EXPO_PUBLIC_OPENAI_API_KEY=sk-...

# Kosi server — YOLO-World + GPT-4o pipeline for image analysis.
# If set, the camera-with-description flow goes through Kosi instead of
# calling OpenAI vision directly. Point at your Mac's LAN IP on port 8000,
# or an ngrok tunnel for off-network demos.
# EXPO_PUBLIC_KOSI_URL=http://10.0.4.230:8000

# --- Live view tuning (safe to tweak or revert) ---
# Capture quality for each live frame sent to /detect.
#   0.4 = original tiny JPEGs, lower accuracy on small parts.
#   0.7 = default. ~2.5x more pixels, noticeably better port/button tagging.
# EXPO_PUBLIC_LIVE_QUALITY=0.7
# Cross-frame IoU tracker + 1.5s coast — smooths boxes so they don't flicker.
#   "1" (default) = on.   "0" = off, revert to raw per-tick boxes.
# EXPO_PUBLIC_LIVE_TRACKING=1

# Auto-diagnosis: when the user asks "what's wrong with my phone" the LLM
# may request diskSpace / internetSpeed checks, the app runs them, and the
# LLM explains the numbers in plain English. Set to "0" to turn off the
# entire feature (schema field is still returned by the model but ignored).
# EXPO_PUBLIC_DIAGNOSTICS_ENABLED=1

# Optional overrides
# EXPO_PUBLIC_OPENAI_CHAT_MODEL=gpt-4o-mini
# EXPO_PUBLIC_OPENAI_VISION_MODEL=gpt-4o
# EXPO_PUBLIC_OPENAI_STT_MODEL=whisper-1
# EXPO_PUBLIC_OPENAI_TTS_MODEL=tts-1
# EXPO_PUBLIC_OPENAI_TTS_VOICE=nova
# EXPO_PUBLIC_LLAMA_MODEL_URL=https://huggingface.co/Qwen/Qwen2.5-0.5B-Instruct-GGUF/resolve/main/qwen2.5-0.5b-instruct-q4_k_m.gguf
